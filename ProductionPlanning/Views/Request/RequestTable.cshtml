@using ProductionPlanning.Extensions
@using ProductionPlanning.ViewModel.Request;
@model RequestTabaleViewModel;

<div id="requestTable">
    @if (@Model.Requests.Count > 0)
    {
        <table id="requestTable" class="table table-striped">

            <tr>
                <th>№</th>
                <th>Прибор</th>
                <th>Статус</th>
                <th>Дата создание</th>
                <th>Дата поставки</th>
                <th>Дата план. отгрузки</th>
                <th>Кол-во</th>
                <th></th>
                <th></th>
            </tr>

            @for (int i = 0; i < Model.Requests.Count; i++)
            {
                <tr class="itemTableHover">
                    <td>@Model.GetNumber(Model.Requests[i])</td>
                    <td>@(Model.Requests[i].Equipment?.Name ?? "-")</td>
                    <td>@Model.Requests[i].Status.ToStringX()</td>
                    <td>@Model.Requests[i].DateCreate.ToString("dd.MM.yyyy")</td>
                    <td>@Model.Requests[i].DateMaxFinish.ToString("dd.MM.yyyy")</td>
                    <td>@(Model.Requests[i].DatePlaningStart?.ToString("dd.MM.yyyy") ?? "-")</td>
                    <td>@Model.Requests[i].Count</td>

                    <!-- Edit -->
                    <td>
                        <a class="btn btn-warning" href="~/Request/EditRequest?_id=@Model.Requests[i].Id">
                            <svg width="17" height="17" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z" />
                            </svg>
                        </a>
                    </td>
                    <td>
                        <a class="btn btn-info" href="~/Request/AddRequestOrder?_rId=@Model.Requests[i].Id">
                            <svg width="17" height="17" fill="currentColor" class="bi bi-plus-circle" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4" />
                            </svg>
                        </a>
                    </td>

                    @* <td>@Model.Requests[i].</td>
                    <td onclick="window.location='/HomeBir8/SensorListByZoneBir8?zoneNum=@Model.zoneList[i].Number&_birId=@Model.elId'">@Model.zoneList[i].Name</td>
                    <td onclick="window.location='/HomeBir8/SensorListByZoneBir8?zoneNum=@Model.zoneList[i].Number&_birId=@Model.elId'">@Model.zoneList[i].Type.ToStringX()</td>

                    <!-- Edit -->
                    <td>
                        <a class="btn btn-warning" href="~/HomeBir8/EditZone?_birId=@Model.elId&_zoneId=@Model.zoneList[i].Id">
                            <svg width="17" height="17" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z" />
                            </svg>
                        </a>
                    </td>
                    <!-- Delete -->
                    <td>
                        <a class="btn btn-danger deleteItemClassZL" id="deleteItemZL" data-path="@Url.Action("DeleteZone", "HomeBir8", new { _zoneId = @Model.zoneList[i].Id, _birId = @Model.elId })" data-bs-toggle="modal" data-bs-target="#staticBackdropZoneList">
                            <svg width="17" height="17" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5ZM11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H2.506a.58.58 0 0 0-.01 0H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1h-.995a.59.59 0 0 0-.01 0H11Zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5h9.916Zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47ZM8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5Z" />
                            </svg>
                        </a>
                    </td> *@
                </tr>
            }
        </table>
    }
    else{
        <h5>Нет заявок</h5>
    }
</div>
