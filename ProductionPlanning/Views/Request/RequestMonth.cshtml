@using ProductionPlanning.ViewModel.Request;
@model ProductsViewModel
@{
    var today = DateTime.Today;
    var todayIndex = Model.Days.FindIndex(d => d.Date == today.Date);
}


@{
    ViewData["Title"] = "Список заявок";
}

<div id="requestsUpdate">
    @{
        await Html.RenderPartialAsync("_RequestMonthPartialView", Model);
    }
</div>

@* Modal for Orders *@
<div class="modal fade" id="detailsModalOrders" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalOrdersTittle">Заказы</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBodyOrders">
                <div class="text-center">
                    <span class="spinner-border"></span> Загрузка...
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal for Request *@
<div class="modal fade" id="detailsModalRequest" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalRequestTittle">О заявке</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBodyRequest">
                <div class="text-center">
                    <span class="spinner-border"></span> Загрузка деталей...
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal для подтверждения удаления Order -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-top mt-4">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header">
                <h5 class="modal-title">Подтверждение удаления</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body-delete-order text-center py-3">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-3 mb-2 d-block"></i>
                <p class="mb-0 fw-semibold">
                    Вы уверены, что хотите удалить этот заказ?
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Удалить</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal для подтверждения удаления Request -->
<div class="modal fade" id="confirmDeleteRequestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-top mt-4">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header">
                <h5 class="modal-title">Подтверждение удаления</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body-delete-order text-center py-3">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-3 mb-2 d-block"></i>
                <p class="mb-0 fw-semibold">
                    Вы уверены, что хотите удалить эту заявку?
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteRequestBtn">Удалить</button>
            </div>
        </div>
    </div>
</div>



<script>
    const isAdmin = @User.IsInRole(Role.Administrator).ToString().ToLower();
    const isManufacture = @User.IsInRole(Role.Manufacture).ToString().ToLower();
    const isSeller = @User.IsInRole(Role.Seller).ToString().ToLower();
    const isHeader = @User.IsInRole(Role.Header).ToString().ToLower();

    let orderIdToDelete = null;
    let orderDateCreate = null;
    let requestIdToDelete = null;
    let requestDateCreate = null;

    function EquipmentClick(id) {

        if (isSeller) {
            window.location.href = '/Request/AddProductionRequest?_id=' + id;
        }
        else{
           return;
        }
    }

    function RequestClick(id) {

        if (isSeller || isManufacture) {
            window.location.href = '/Request/EditRequest?_id=' + id;
        }
        else if (isHeader || isAdmin) {
            //alert("Header => Show Modal with RequestInfo: " + id);
             $('#modalRequestTittle').text('О заявке');
             $('#modalBodyRequest').load('/Request/RequestInfoPartial?_requestId=' + id, function () {
                $('#detailsModalRequest').modal('show');
             }); 
        }
        else {
            return;
        }
    }
    
    function DayClick(date, id) {
        
        if (isSeller || isHeader || isAdmin) {
            $('#modalOrdersTittle').text('Заказы');
            $('#modalBodyOrders').load('/Request/OrdersRequestDayPartial?_date=' + date + "&_requestId=" + id, function () {
                requestNumValue
                const requestNumText = $('#modalBodyOrders').find('#requestNumValue').val();

                if (requestNumText) {
                    $('#modalOrdersTittle').text('Заказы по заявке №' + requestNumText);
                } else {
                    $('#modalOrdersTittle').text('Заказы');
                }

                $('#detailsModalOrders').modal('show');
            });

        }
        if (isManufacture) {
            window.location.href = '/Request/AddRequestOrder?_rId=' + id + "&_date=" + date;
        }
        else {
            return;
        }
    }

    function DateClick(date) {
        
        if (isSeller || isHeader || isManufacture || isAdmin) {

            // Сначала очистка заголовка
            $('#modalOrdersTittle').text('Заказы');

            $('#modalBodyOrders').load('/Request/OrdersDayPartial?_date=' + date, function () {
                const dateText = $('#modalBodyOrders').find('#ordersDateValue').val();

                if (dateText) {
                    $('#modalOrdersTittle').text('Заказы за ' + dateText);
                } else {
                    $('#modalOrdersTittle').text('Заказы');
                }
                $('#detailsModalOrders').modal('show');
            });
        }
        else {
            return;
        }
    }

    function showContextMenu(event, tdElement, requestId) {
        event.preventDefault();
        event.stopPropagation();
    
        console.log("id = " + requestId);

        // Скрываем все открытые меню
        document.querySelectorAll(".context-menu").forEach(menu => menu.style.display = "none");

        const menu = tdElement.querySelector(".context-menu");
        menu.style.display = "block";
    
        // Сохраняем ID запроса в data-атрибуте меню
        menu.dataset.requestId = requestId;
        menu.dataset.tdElement = requestId; // можно сохранить для обратной связи
    
        // Позиционируем меню
        const menuRect = menu.getBoundingClientRect();
        let left = event.clientX;
        let top = event.clientY;
    
        // Проверяем границы экрана
        if (left + menuRect.width > window.innerWidth) {
            left = window.innerWidth - menuRect.width - 5;
        }
        if (top + menuRect.height > window.innerHeight) {
            top = window.innerHeight - menuRect.height - 5;
        }
    
        menu.style.left = left + "px";
        menu.style.top = top + "px";
    
        // Возвращаем false для предотвращения других обработчиков
        return false;
    }

    // Скрытие меню при клике в любом месте
    document.addEventListener("click", function() {
        document.querySelectorAll(".context-menu").forEach(menu => menu.style.display = "none");
    });

    function editRequest(menuItem){
        // Находим ближайшее меню
        const menu = menuItem.closest('.context-menu');
        const requestId = menu.dataset.requestId;    
        // Скрываем меню
        menu.style.display = 'none';

        if (isSeller || isManufacture) {
            window.location.href = '/Request/EditRequest?_id=' + id;
        }
    }
    function viewDetails(menuItem){
        event.stopPropagation();
         // Находим ближайшее меню
        const menu = menuItem.closest('.context-menu');
        const requestId = menu.dataset.requestId;    
        // Скрываем меню
        menu.style.display = 'none';

        $('#modalRequestTittle').text('О заявке');
        $('#modalBodyRequest').load('/Request/RequestInfoPartial?_requestId=' + requestId, function () {
            $('#detailsModalRequest').modal('show');
        });        
    }

    function deleteRequest(event, element) {
        event.preventDefault();  // Предотвращаем стандартное поведение
        event.stopPropagation(); // Останавливаем всплытие к родительскому onclick

        // Получаем ID из data-атрибута
        var requestId = element.getAttribute('data-request-id');
        var monthDate = element.getAttribute('data-request-datecreate');

        // Настраиваем модальное окно
        var modal = new bootstrap.Modal(document.getElementById('confirmDeleteRequestModal'));

        // Устанавливаем ID в форму
        // var deleteForm = document.querySelector('#confirmDeleteRequestModal');
        // var input = deleteForm.querySelector('input[name="id"]') ||
        //     (function () {
        //         var inp = document.createElement('input');
        //         inp.type = 'hidden';
        //         inp.name = 'id';
        //         deleteForm.appendChild(inp);
        //         return inp;
        //     })();
        // input.value = requestId;

        requestIdToDelete = requestId;
        requestDateCreate = monthDate;
        // Показываем модальное окно
        modal.show();
    }
    document.getElementById('confirmDeleteRequestBtn').addEventListener('click', function () {
        if (!requestIdToDelete) return;

        $.ajax({
            url: '/Request/DeleteRequest', // путь к методу контроллера
            type: 'POST',
            data: { id: requestIdToDelete },
            success: function () {
                // Закрываем модальное окно
                const modalEl = document.getElementById('confirmDeleteRequestModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                modal.hide();

                // Преобразуем дату
                let orderDateCreateTemp = requestDateCreate;
                if (!(orderDateCreate instanceof Date)) {
                    orderDateCreate = new Date(orderDateCreate); // конвертация строки в Date
                }

                const year = orderDateCreate.getFullYear();
                const month = orderDateCreate.getMonth(); // 0-based
                const day = orderDateCreate.getDate();
                const newDate = new Date(year, month, day, 0, 0, 0);

                const dateStr = formatDateLocal(newDate);

                // Обновляем месячную таблицу
                loadScheduleForMonth(orderDateCreateTemp);
            },
            error: function () {
                alert('Ошибка при удалении заявки');
            }
        });
        
    });
    // function deleteRequest(menuItem){
    //     event.stopPropagation();
    //      // Находим ближайшее меню
    //     const menu = menuItem.closest('.context-menu');
    //     const requestId = menu.dataset.requestId;    
    //     // Скрываем меню
    //     menu.style.display = 'none';
    //     alert("deleteRequest = " + requestId);
    // }
</script>

@* Script for DeleteOrder *@
<script>
    
    // При нажатии на кнопку "Удалить" — сохраняем ID
    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.delete-order-btn');
        if (!btn) return;

        orderIdToDelete = btn.dataset.orderId;
        orderDateCreate = btn.dataset.orderDate;

        // alert("orderDateCreate = " + orderDateCreate);
    });

    // При подтверждении удаления
    document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
        if (!orderIdToDelete) return;

        $.ajax({
            url: '/Request/DeleteOrder', // путь к методу контроллера
            type: 'POST',
            data: { id: orderIdToDelete },
            success: function () {
                // Закрываем модальное окно
                const modalEl = document.getElementById('confirmDeleteModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                modal.hide();

                // Удаляем карточку заказа
                // document.querySelector(`[data-order-id="${orderIdToDelete}"]`)
                //     .closest('.list-group-item')
                //     .remove();

                
                // Преобразуем дату
                let orderDateCreateTemp = orderDateCreate;
                if (!(orderDateCreate instanceof Date)) {
                    orderDateCreate = new Date(orderDateCreate); // конвертация строки в Date
                }
                
                const year = orderDateCreate.getFullYear();
                const month = orderDateCreate.getMonth(); // 0-based
                const day = orderDateCreate.getDate();
                const newDate = new Date(year, month, day, 0, 0, 0);

                const dateStr = formatDateLocal(newDate);

                
                // Обновляем таблицу модального окна
                $('#modalBodyOrders').load('/Request/OrdersDayPartial?_date=' + dateStr, function () {
                    const dateText = $('#modalBodyOrders').find('#ordersDateValue').val();
                    console.log("dateText : " + dateText);

                    if (dateText) {
                        $('#modalOrdersTittle').text('Заказы за ' + dateText);
                    } else {
                        $('#modalOrdersTittle').text('Заказы');
                    }
                    // $('#detailsModalOrders').modal('show');
                });

                // Обновляем месячную таблицу
                loadScheduleForMonth(orderDateCreateTemp);
            },
            error: function () {
                alert('Ошибка при удалении заказа');
            }
        });
    });

    function formatDateLocal(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        // return `${year}-${month}-${day}`;
        return `${day}-${month}-${year}`;
    }
    function formatDateLocal1(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        // return `${year}-${month}-${day}`;
        return `${year}-${month}-${day}`;
    }
</script>
