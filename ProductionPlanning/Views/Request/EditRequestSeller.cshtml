@using ProductionPlanning.Extensions
@using ProductionPlanning.ViewModel.Request;
@model EditRequestViewModel;

@{
    ViewData["Title"] = $"Заявка - {@Model.App.GetNumString()}";
}
@{
    var today = DateTime.Now.ToString("yyyy-MM-dd");
}

<div class="col-md-8">
    <h1 class="h3 mb-0">
        <svg width="25" height="25" fill="#3498db" class="bi bi-file-earmark-plus" viewBox="0 0 16 16">
            <path d="M8 6.5a.5.5 0 0 1 .5.5v1.5H10a.5.5 0 0 1 0 1H8.5V11a.5.5 0 0 1-1 0V9.5H6a.5.5 0 0 1 0-1h1.5V7a.5.5 0 0 1 .5-.5" />
            <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
        </svg>
        Редактировать заявку <span style="color: #00BFFF;">@Model.App.GetNumString()</span>
    </h1>
    <p class="text-muted mb-0">Редактирование заявки</p>
</div>
<hr />

<form asp-action="EditRequest" method="post" class="needs-validation" novalidate>
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
        </div>
    }
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="App.Id" />
    @* <input type="hidden" asp-for="App.DatePlaningStart" />
    <input type="hidden" asp-for="App.DatePlaningFinish" />
    <input type="hidden" asp-for="App.Status" />
    <input type="hidden" asp-for="App.DayNumber" /> *@

    <div class="alert alert-light" role="alert">
        <h5 class="alert-heading">
            <svg width="25" height="25" fill="#3498db" class="bi bi-info-circle" viewBox="0 0 17 17">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
            </svg>
            Информация о заявке
        </h5>
        <div class="row g-2">
            <div class="col-md-6 col-lg-4">
                <label asp-for="App.AppType" class="form-label"></label>
                <select class="form-select" asp-for="App.AppType" asp-items="ViewBag.rType" required></select>
            </div>
            <div class="col-md-6 col-lg-4">
                <label asp-for="App.MonthDatePlanning" class="form-label"></label>
                <select class="form-select" asp-for="App.MonthDatePlanning" asp-items="ViewBag.Months" required></select>
            </div>
        </div>
        @* <hr>
        <p class="mb-0">Whenever you need to, be sure to use margin utilities to keep things nice and tidy.</p> *@
    </div>

    <div class="alert alert-light" role="alert">
        <h5 class="alert-heading">
            <svg width="25" height="25" fill="#3498db" class="bi bi-info-circle" viewBox="0 0 17 17">
                <path fill-rule="evenodd" d="M6 3.5A1.5 1.5 0 0 1 7.5 2h1A1.5 1.5 0 0 1 10 3.5v1A1.5 1.5 0 0 1 8.5 6v1H14a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 2 7h5.5V6A1.5 1.5 0 0 1 6 4.5zm-6 8A1.5 1.5 0 0 1 1.5 10h1A1.5 1.5 0 0 1 4 11.5v1A1.5 1.5 0 0 1 2.5 14h-1A1.5 1.5 0 0 1 0 12.5zm6 0A1.5 1.5 0 0 1 7.5 10h1a1.5 1.5 0 0 1 1.5 1.5v1A1.5 1.5 0 0 1 8.5 14h-1A1.5 1.5 0 0 1 6 12.5zm6 0a1.5 1.5 0 0 1 1.5-1.5h1a1.5 1.5 0 0 1 1.5 1.5v1a1.5 1.5 0 0 1-1.5 1.5h-1a1.5 1.5 0 0 1-1.5-1.5z" />
            </svg>
            Продукция
        </h5>
        <div class="col-md-6 col-lg-4 mb-3">
            <label asp-for="App.EquipmentId" class="form-label d-block"></label>
            <select class="form-select selectpicker"
                    asp-for="App.EquipmentId"
                    id="searchable-select"
                    data-live-search="true"
                    title="Выберите элемент..."
                    asp-items="ViewBag.equipmentList"
                    disabled
                    required></select>
            <span asp-validation-for="App.EquipmentId" class="invalid-feedback d-block"></span>
        </div>
        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <label asp-for="App.Count" class="form-label"></label>
                <input class="form-control" type="number" asp-for="App.Count" min="1" required />
                <span asp-validation-for="App.Count" class="text-danger small invalid-feedback"> Введите значение больше 0</span>
            </div>
            <div class="col-md-6 col-lg-4 mb-3">
                <label asp-for="App.DateMaxFinish" class="form-label"></label>
                <input asp-for="App.DateMaxFinish" type="date" class="form-control" min="@today" required />
                <span asp-validation-for="App.DateMaxFinish" class="text-danger small invalid-feedback">
                    Введите значение, большее или равное @today
                </span>
            </div>
        </div>
        <hr />
        <div class="col-md-12 mb-3">
            <label class="form-label d-block mb-2">
                <svg width="16" height="16" fill="#3498db" class="bi bi-hourglass-split" viewBox="0 0 16 16">
                    <path d="M2.5 15a.5.5 0 1 1 0-1h1v-1a4.5 4.5 0 0 1 2.557-4.06c.29-.139.443-.377.443-.59v-.7c0-.213-.154-.451-.443-.59A4.5 4.5 0 0 1 3.5 3V2h-1a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-1v1a4.5 4.5 0 0 1-2.557 4.06c-.29.139-.443.377-.443.59v.7c0 .213.154.451.443.59A4.5 4.5 0 0 1 12.5 13v1h1a.5.5 0 0 1 0 1zm2-13v1c0 .537.12 1.045.337 1.5h6.326c.216-.455.337-.963.337-1.5V2zm3 6.35c0 .701-.478 1.236-1.011 1.492A3.5 3.5 0 0 0 4.5 13s.866-1.299 3-1.48zm1 0v3.17c2.134.181 3 1.48 3 1.48a3.5 3.5 0 0 0-1.989-3.158C8.978 9.586 8.5 9.052 8.5 8.351z" />
                </svg>
                @Html.DisplayNameFor(m => m.App.AppUrgency)
            </label>

            <div class="btn-group gap-2" role="group" aria-label="Urgency">
                @foreach (var item in (SelectList)ViewBag.urgency)
                {
                    string outlineClass = item.Value.ToString() switch
                    {
                        "Low" => "btn-outline-primary",
                        "Medium" => "btn-outline-success",
                        "High" => "btn-outline-danger",
                        _ => "btn-outline-secondary"
                    };

                    string iconClass = item.Value.ToString() switch
                    {
                        "Low" => "bi-circle",
                        "Medium" => "bi-exclamation-circle",
                        "High" => "bi-exclamation-triangle-fill",
                        _ => ""
                    };

                    <input type="radio"
                           class="btn-check"
                           asp-for="App.AppUrgency"
                           value="@item.Value"
                           id="urgency_@item.Value"
                           autocomplete="off" />

                    <label class="btn @outlineClass"
                           for="urgency_@item.Value">
                        <i class="bi @iconClass me-1"></i>
                        @item.Text
                    </label>
                }
            </div>

            <span asp-validation-for="App.AppUrgency" class="text-danger small d-block mt-1"></span>
        </div>
    </div>

    @* Note *@
    <div class="alert alert-light" role="alert">
        <h5 class="alert-heading">
            <svg width="25" height="25" fill="#3498db" class="bi bi-check2-circle" viewBox="0 0 16 16">
                <path d="M2.5 8a5.5 5.5 0 0 1 8.25-4.764.5.5 0 0 0 .5-.866A6.5 6.5 0 1 0 14.5 8a.5.5 0 0 0-1 0 5.5 5.5 0 1 1-11 0" />
                <path d="M15.354 3.354a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0z" />
            </svg>
            Метка
        </h5>

        <div class="card mb-3">

            <!-- HEADER -->
            <div class="card-header d-flex justify-content-between align-items-center">

                <!-- Левая часть -->
                <div class="form-check m-0">
                    <input class="form-check-input"
                           type="checkbox"
                           id="useNoteCheckbox"
                           asp-for="IsUseNote"
                           />
                    <input type="hidden" id="IsNoteChB" name="IsUseNoteChB" value="" />
                    <label class="form-check-label fw-semibold"
                           for="useNoteCheckbox">
                        Использовать метку
                    </label>
                </div>

                <!-- Правая часть -->
                <button type="button"
                        id="createNoteBtn"
                        class="btn btn-sm btn-outline-success"
                        data-bs-toggle="modal"
                        data-bs-target="#noteModal">
                    + Создать новую метку
                </button>
            </div>

            <!-- BODY -->
            <div class="card-body d-none" id="noteBox">
                <label asp-for="App.NoteId" class="form-label"></label>

                <select class="selectpicker"
                        asp-for="App.NoteId"
                        asp-items="ViewBag.noteList"
                        id="NoteId"
                        data-live-search="true"
                        title="Выберите метку..."
                        data-width="100%">
                </select>

                <div id="noteInfo" class="mt-2 d-none border-start border-4 border-primary ps-2">
                    <div><b>Заказчик:</b> <span id="customerInfo"></span></div>
                    <div><b>Описание:</b> <span id="descriptionInfo"></span></div>
                </div>

                <span asp-validation-for="App.NoteId" class="invalid-feedback d-block"></span>
            </div>

        </div>
    </div>

    <div class="col-12">
        <input type="submit" class="btn btn-success" value="Сохранить" />
        <button type="button" class="btn btn-secondary" onclick="history.back();">Отмена</button>
    </div>
</form>

@* Note Modal *@
<div class="modal fade" id="noteModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <!-- Форма -->
            <form id="noteForm" class="needs-validation" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title">
                        <svg width="25" height="25" fill="#3498db" class="bi bi-check2-circle" viewBox="0 0 16 16">
                            <path d="M2.5 8a5.5 5.5 0 0 1 8.25-4.764.5.5 0 0 0 .5-.866A6.5 6.5 0 1 0 14.5 8a.5.5 0 0 0-1 0 5.5 5.5 0 1 1-11 0" />
                            <path d="M15.354 3.354a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0z" />
                        </svg>
                        Новая метка
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label" for="noteName">Название</label>
                            <input id="noteName" class="form-control" required minlength="3" />
                            <div class="invalid-feedback">
                                Введите название (минимум 3 символа)
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="noteCustomer">Заказчик</label>
                            <input id="noteCustomer" class="form-control" />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label" for="noteDescription">Описание</label>
                            <textarea id="noteDescription" class="form-control"></textarea>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-success" id="saveNote">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const $select = $('.selectpicker');

            $select.selectpicker();

            $select.on('changed.bs.select', function () {
                const $this = $(this);
                const val = $this.val();

                // Снимаем или добавляем классы Bootstrap
                if (val && val.length > 0) {
                    $this.removeClass('is-invalid').addClass('is-valid');
                } else {
                    $this.removeClass('is-valid').addClass('is-invalid');
                }

                // Обновляем состояние валидности для unobtrusive validation
                $this.valid(); // <- ключевой момент
            });
        });
    </script>

    @* Note Script *@
    <script>
        $(function () {

            function syncNoteUI() {
                const isChecked = $('#useNoteCheckbox').is(':checked');

                $('#noteBox').toggleClass('d-none', !isChecked);
                $('#createNoteBtn').toggleClass('d-none', !isChecked);
                // Обновление значения hidden input
                $('#IsNoteChB').val(isChecked.toString());
            }

            // первичная инициализация при загрузке
            syncNoteUI();
            // вызвать обработчик смены (AJAX на информацию)
            $('#NoteId').trigger('changed.bs.select');

            // Показ / скрытие блока по чекбоксу
            $('#useNoteCheckbox').on('change', function () {
                $('#noteBox').toggleClass('d-none', !this.checked);
                // Показ / скрытие кнопки
                $('#createNoteBtn').toggleClass('d-none', !this.checked);

                // Обновление значения hidden input
                $('#IsNoteChB').val(this.checked ? 'true' : 'false');

            });
        });

        // Save Note
        $(function () {
            const $form = $('#noteForm');
            const $select = $('#NoteId');

            // Инициализация selectpicker один раз
            $select.selectpicker();

            $form.on('submit', function (e) {
                e.preventDefault();
                e.stopPropagation();

                $form.addClass('was-validated');
                if (!$form[0].checkValidity()) return;

                const model = {
                    Name: $('#noteName').val().trim(),
                    Customer: $('#noteCustomer').val().trim(),
                    Description: $('#noteDescription').val().trim()
                };

                $.ajax({
                    url: '@Url.Action("CreateNote", "Notes")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(model),
                    success: function (result) {
                        if (!result.success) {
                            alert("Ошибка сервера");
                            return;
                        }

                        $('#noteModal').modal('hide');

                        // Обновляем selectpicker
                        updateSelectPicker($select, result.notes, result.newNoteId);

                        // Сбрасываем форму
                        $form[0].reset();
                        $form.removeClass('was-validated');
                    },
                    error: function () {
                        alert('Ошибка при сохранении метки');
                    }
                });
            });

            // Универсальная функция обновления selectpicker
            function updateSelectPicker($select, options, selectedId) {
                if (!$select || !options) return;

                // 1️ уничтожаем selectpicker
                $select.selectpicker('destroy');

                // 2️ очищаем select
                $select.empty();

                // 3️ добавляем новые опции
                options.forEach(function (opt) {
                    $select.append($('<option>', {
                        value: opt.id,
                        text: opt.text
                    }));
                });

                // Инициализация selectpicker заново
                $select.selectpicker({
                    liveSearch: true,
                    width: '100%'
                });

                // Выбираем новую заметку по id
                if (selectedId) {
                    $select.selectpicker('val', selectedId);
                    $select.selectpicker('render'); // обновляем визуально
                }

                // вызвать обработчик смены (AJAX на информацию)
                $('#NoteId').trigger('changed.bs.select');
            }
        });

        // Update Selected Note info
        // Делегированное событие changed.bs.select
        $(document).on('changed.bs.select', '#NoteId', function () {
            const id = $(this).val();
            if (!id) {
                $('#noteInfo').addClass('d-none');
                return;
            }

            $.ajax({
                url: '/Notes/GetNoteInfo',
                type: 'GET',
                data: { id: id },
                success: function (data) {
                    $('#noteInfo').removeClass('d-none');
                    $('#customerInfo').text(data.customer ?? '—');
                    $('#descriptionInfo').text(data.description ?? '—');
                }
            });
        });



    </script>
}