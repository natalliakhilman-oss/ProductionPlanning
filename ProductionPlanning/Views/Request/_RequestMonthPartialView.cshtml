@using ProductionPlanning.Extensions
@using ProductionPlanning.ViewModel.Request;
@using System.Globalization
@model ProductsViewModel
@{
    var today = DateTime.Today;
    var todayIndex = Model.Days.FindIndex(d => d.Date == today.Date);
}

<div id="monthTable">
    <table class="schedule-table">
        <input type="hidden" asp-for="Date" id="scheduleDate" value="@Model.Date.ToString("yyyy-MM-dd")" />
        <thead>
            <tr>
                <th class="th-blue" rowspan="2">Тип изделия</th>
                <th class="th-blue" rowspan="2">№ заявки</th>
                <th class="th-blue" rowspan="2">Статус</th>
                <th class="th-blue" rowspan="2">Отгружено/План</th>
                <th class="th-blue" rowspan="2">План.нач.произ-ва</th>
                <th class="th-blue" rowspan="2">Поставка</th>
                <th class="th-blue" rowspan="2">Фактич.отгрузка</th>
                <th class="info-cell" colspan="@Model.Days.Count">
                    <div class="month-navigation">
                        <button class="nav-arrow prev-month" onclick="changeMonth(-1)">
                            <svg width="16" height="16" viewBox="0 0 24 24">
                                <path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" />
                            </svg>
                        </button>

                        <span class="month-title">
                            @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.Date.Month)
                            @Model.Date.Year
                        </span>

                        <button class="nav-arrow next-month" onclick="changeMonth(1)">
                            <svg width="16" height="16" viewBox="0 0 24 24">
                                <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" />
                            </svg>
                        </button>
                    </div>
                </th>
            </tr>
            <tr>
                @for (int i = 0; i < Model.Days.Count; i++)
                {
                    <th class="@(i == todayIndex ? "today-col" : "") clickable"
                        onclick="DateClick('@Model.Days[i].ToString("yyyy-MM-dd")')">
                        @Model.Days[i].Day
                    </th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var product in Model.ProductGroups)
            {
                var first = true;
                foreach (var requestVM in product.RequestVMList)
                {
                    <tr>
                        @if (first)
                        {
                            <td rowspan="@product.RequestVMList.Count"
                                class="product-cell clickable" onclick="EquipmentClick('@product.Equipment.Id')">
                                @product.Equipment.Name
                            </td>
                            first = false;
                        }

                        <td class="order priority-@requestVM.Request.AppUrgency.ToString().ToLower() clickable" 
                                onclick="RequestClick('@requestVM.Request.Id')"
                                oncontextmenu="showContextMenu(event, this, '@requestVM.Request.Id')">
                             @requestVM.Request.GetNumString()

                            @* Context Menu only for Seller and Manufacture *@
                            @if (User.IsInRole(Role.Seller) || User.IsInRole(Role.Manufacture))
                            {
                                <!-- Контекстное меню для этой ячейки -->
                                <div class="context-menu">
                                    <ul>
                                        <li onclick="editRequest(this)">
                                            <svg width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                                            </svg>
                                            Редактировать
                                        </li>
                                        <li onclick="viewDetails(this)">
                                            <svg width="16" height="16" fill="currentColor" class="bi bi-info-square" viewBox="0 0 16 16">
                                                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                                                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                                            </svg>
                                            Детали
                                        </li>
                                        @if(User.IsInRole(Role.Seller))
                                        {
                                            @* <li class="text-danger" onclick="deleteRequest(this)">
                                                <svg width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                                                </svg>
                                                Удалить
                                            </li> *@
                                            <li class="text-danger"
                                                onclick="deleteRequest(event, this)"
                                                data-request-id="@requestVM.Request.Id"
                                                data-request-datecreate="@requestVM.Request.MonthDatePlanning">
                                                <svg width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                                                </svg>
                                                Удалить
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }

                        </td>
                        <td class="order status-@requestVM.Request.Status.ToString().ToLower()">
                            @requestVM.Request.Status.ToStringX()
                        </td>
                        <td class="info-cell">@requestVM.Request.GetOrderProgress()</td>
                        <td class="info-cell">@requestVM.Request.DatePlaningStart.GetDate()</td>
                        <td class="info-cell">@requestVM.Request.DateMaxFinish.GetDate()</td>
                        <td class="info-cell">@requestVM.Request.DateFinish.GetDate()</td>

                        @for (int i = 0; i < requestVM.Calendar.Count; i++)
                        {
                           @*  <td class="
                                day-cell
                                priority-@requestVM.Request.AppUrgency.ToString().ToLower()
                                @(i == todayIndex ? "today-col" : "")"> *@
                            <td class="
                                 day-cell
                                 clickable
                                 @(requestVM.Calendar[i].IsInRange ? $"priority-{requestVM.Request.AppUrgency.ToString().ToLower()}" : "")
                                 @(i == todayIndex ? "today-col" : "")"
                                onclick="DayClick('@requestVM.Calendar[i].Date.ToString("yyyy-MM-dd")', '@requestVM.Request.Id')">

                                @requestVM.Calendar[i].Count
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="total">
        Отгружено за @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.Date.Month) : <b>@Model.TotalOrderCount</b>
    </div>
</div>

<script>
    
    function changeMonth(offset) {
        // Получаем значение из hidden input
        const dateString = document.getElementById('scheduleDate').value; // "2024-01-24"
        const currentDate = new Date(dateString + 'T00:00:00'); // Добавляем время для корректного парсинга

        const year = currentDate.getFullYear();
        const month = currentDate.getMonth() + offset;
        const newDate = new Date(year, month, 1, 0, 0, 0); // 1-е число месяца

        // Форматируем только дату (без времени)
        const year1 = newDate.getFullYear();
        const month1 = newDate.getMonth() + 1;
        const day1 = newDate.getDate();
        // Формат YYYY-MM-DD
        const dateStr = `${year1}-${month1.toString().padStart(2, '0')}-${day1.toString().padStart(2, '0')}`;

        // Вызываем метод для обновления данных
        loadScheduleForMonth(dateStr);
    }

    function loadScheduleForMonth(dateStr) {

        let date;

        if (typeof dateStr === 'string') {
            // Поддержка форматов: "DD.MM.YYYY", "DD.MM.YYYY HH:mm:ss", "YYYY-MM-DD"
            if (dateStr.includes('.')) {
                const parts = dateStr.split(' ')[0].split('.'); // "07.01.2026"
                const day = parseInt(parts[0], 10);
                const month = parseInt(parts[1], 10) - 1; // 0-based
                const year = parseInt(parts[2], 10);
                date = new Date(year, month, day);
            } else if (dateStr.includes('-')) {
                const parts = dateStr.split(' ')[0].split('-'); // "2026-01-07"
                const year = parseInt(parts[0], 10);
                const month = parseInt(parts[1], 10) - 1;
                const day = parseInt(parts[2], 10);
                date = new Date(year, month, day);
            } else {
                date = new Date(dateStr); // fallback
            }
        } else if (dateStr instanceof Date) {
            date = new Date(dateStr.getFullYear(), dateStr.getMonth(), dateStr.getDate());
        } else {
            console.error("Неверный формат даты:", dateStr);
            return;
        }

        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const formattedDate = `${year}-${month}-${day}`;


        fetch(`/Request/RequestMonthPartial?_date=${formattedDate}`)
            .then(response => response.text())
            .then(html => {
                // Обновляем только таблицу
                document.querySelector('#monthTable').outerHTML = html;
                // Обновляем currentDate
                currentDate = date;
            })
            .catch(error => console.error('Ошибка:', error));
       
    }

    // Альтернатива: передача в метод с сохранением других параметров
    function changeMonthWithData(offset) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = window.location.pathname;

        // Копируем все текущие параметры
        const currentDateInput = document.createElement('input');
        currentDateInput.type = 'hidden';
        currentDateInput.name = 'date';
        currentDateInput.value = new Date(
            currentDate.getFullYear(),
            currentDate.getMonth() + offset,
            1
        ).toISOString();

        form.appendChild(currentDateInput);
        document.body.appendChild(form);
        form.submit();
    }
</script>