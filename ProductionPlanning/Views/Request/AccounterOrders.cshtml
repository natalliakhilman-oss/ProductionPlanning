@using ProductionPlanning.ViewModel.Request
@model AccounterOrderListViewModel
@{
    ViewData["Title"] = "Заказы";
}

@* <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" /> *@

<div class="container mt-4">
  <!-- Панель сортировки -->
  @*   <div class="card mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Сортировка:</label>
                </div>
                <div class="col-md-9">
                    <div class="btn-group" role="group">
                        <a asp-action="Index"
                           asp-route-sortOrder="created_desc"
                           class="btn @(Model.CurrentSortOrder == "created_desc" ? "btn-primary" : "btn-outline-primary")">
                            <i class="fas fa-calendar-alt"></i> Сначала новые по созданию
                        </a>
                        <a asp-action="Index"
                           asp-route-sortOrder="accepted_desc"
                           class="btn @(Model.CurrentSortOrder == "accepted_desc" ? "btn-primary" : "btn-outline-primary")">
                            <i class="fas fa-check-circle"></i> Сначала принятые
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div> *@
    <div class="col-md-8">
        <h1 class="h3 mb-0">
            <svg width="25" height="25" fill="#3498db" class="bi bi-file-earmark-plus" viewBox="0 0 16 16">
                <path d="M8 6.5a.5.5 0 0 1 .5.5v1.5H10a.5.5 0 0 1 0 1H8.5V11a.5.5 0 0 1-1 0V9.5H6a.5.5 0 0 1 0-1h1.5V7a.5.5 0 0 1 .5-.5" />
                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
            </svg>
            Учет продукции <span style="color: #00BFFF;"></span>
        </h1>
        <p class="text-muted mb-0">Таблица для учета готовой продукции</p>
    </div>
    <hr />
    @if (@Model.Orders.Count > 0)
    {
        <!-- Таблица заказов -->
        <div class="table-responsive">
            <table class="table table-hover table-bordered">
                <thead>
                    <tr>
                        <th>№</th>
                        <th>Дата</th>
                        <th>Изделие</th>
                        <th>Количество</th>
                        <th>Статус</th>
                        <th>Примечание</th>
                        <th>Исполнитель</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody id="ordersTableBody">
                    @{
                        int rowNumber = ((Model.Pagination.CurrentPage - 1) * Model.Pagination.PageSize) + 1;
                    }
                    @foreach (var order in Model.Orders)
                    {
                        <tr id="order-@order.Id" class="@(order.StatusOrder == Order.OrderStatus.Accepted ? "table-success" : "")">
                            <td>@(rowNumber++)</td>
                            <td class="date-insert">@order.DateInsert.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@order.ProductRequest.Equipment.Name</td>
                            <td>@order.Count</td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(order.StatusOrder) status-badge">
                                    @GetStatusDescription(order.StatusOrder)
                                </span>
                            </td>
                            <td>@(order.Description ?? "-")</td>
                            <td>@(order.User?.UserName ?? "-")</td>
                            <td>
                                @if (order.StatusOrder != Order.OrderStatus.Accepted && order.StatusOrder != Order.OrderStatus.Canceled)
                                {
                                    <button class="btn btn-sm btn-success accept-order"
                                            data-order-id="@order.Id"
                                            title="Отметить как принято">
                                        <i class="fas fa-check"></i> Принять
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <h5>Нет заявок</h5>
    }



    <!-- Пагинация -->
    @if (Model.Pagination.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="AccounterOrders"
                       asp-route-page="@(Model.Pagination.CurrentPage - 1)"
                       asp-route-sortOrder="@Model.CurrentSortOrder">
                        <i class="fas fa-chevron-left"></i> Назад
                    </a>
                </li>

                @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Pagination.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="AccounterOrders"
                           asp-route-page="@i"
                           asp-route-sortOrder="@Model.CurrentSortOrder">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="AccounterOrders"
                       asp-route-page="@(Model.Pagination.CurrentPage + 1)"
                       asp-route-sortOrder="@Model.CurrentSortOrder">
                        Вперед <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }

    <!-- Информация о записях -->
    <div class="text-muted text-center mt-2">
        Показано @Model.Orders.Count() из @Model.Pagination.TotalCount записей
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            // Обработчик для кнопок принятия заказа
            $('.accept-order').click(function() {
                var button = $(this);
                var orderId = button.data('order-id');
                var row = $('#order-' + orderId);

                // Блокируем кнопку на время запроса
                button.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Обработка...');

                // Отправляем AJAX запрос
                $.ajax({
                    url: '@Url.Action("UpdateStatus", "Request")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ id: orderId }),
                    success: function(response) {
                        if (response.success) {
                            // Обновляем строку таблицы
                            row.addClass('table-success');

                            // Обновляем статус
                            row.find('.status-badge')
                               .removeClass('bg-warning bg-info bg-secondary')
                               .addClass('bg-success')
                               .text('Принята на учет');

                            // Обновляем дату вставки
                            row.find('.date-insert').text(response.dateInsert);

                            // Убираем кнопку
                            button.closest('td').html('<span class="text-muted">—</span>');

                            // Показываем уведомление об успехе
                            showNotification('success', 'Статус заказа успешно обновлен');
                        } else {
                            // Возвращаем кнопку в исходное состояние
                            button.prop('disabled', false)
                                  .html('<i class="fas fa-check"></i> Принять');

                            // Показываем ошибку
                            showNotification('error', response.message || 'Произошла ошибка при обновлении статуса');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('AJAX Error:', error);

                        // Возвращаем кнопку в исходное состояние
                        button.prop('disabled', false)
                              .html('<i class="fas fa-check"></i> Принять');

                        // Показываем ошибку
                        showNotification('error', 'Ошибка соединения с сервером');
                    }
                });
            });

            // Функция для показа уведомлений
            function showNotification(type, message) {
                // Проверяем, существует ли уже контейнер для уведомлений
                var notificationContainer = $('#notificationContainer');
                if (notificationContainer.length === 0) {
                    notificationContainer = $('<div id="notificationContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>');
                    $('body').append(notificationContainer);
                }

                var alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
                var icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';

                var notification = $('<div class="alert ' + alertClass + ' alert-dismissible fade show" role="alert">' +
                    '<i class="fas ' + icon + ' me-2"></i>' + message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                    '</div>');

                notificationContainer.append(notification);

                // Автоматически скрываем через 5 секунд
                setTimeout(function() {
                    notification.fadeOut(function() {
                        $(this).remove();
                    });
                }, 5000);
            }
        });
    </script>
}

@functions {
    private string GetStatusDescription(Order.OrderStatus status)
    {
        return status switch
        {
            Order.OrderStatus.No => "Нет статуса",
            Order.OrderStatus.Created => "Создана производством",
            Order.OrderStatus.Accepted => "Принята на учет",
            Order.OrderStatus.Canceled => "Отменена",
            _ => status.ToString()
        };
    }

    private string GetStatusBadgeClass(Order.OrderStatus status)
    {
        return status switch
        {
            Order.OrderStatus.No => "bg-secondary",
            Order.OrderStatus.Created => "bg-warning text-dark",
            Order.OrderStatus.Accepted => "bg-success",
            Order.OrderStatus.Canceled => "bg-danger",
            _ => "bg-secondary"
        };
    }
}